# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase (backend — set in Netlify dashboard, not here)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (backend — set in Netlify dashboard)
# ANTHROPIC_API_KEY=

# Admin panel passwords (server-side only — NOT prefixed with VITE_, never bundled into JS)
# These are validated in netlify/functions/auth.js
ADMIN_PW_OWNER=change-me-owner
ADMIN_PW_CM=change-me-cm
ADMIN_PW_PUB=change-me-pub

# Secret used to sign admin session tokens — generate with:
# node -e "require('crypto').randomBytes(32, (_,b)=>console.log(b.toString('hex')))"
ADMIN_JWT_SECRET=change-me-generate-a-random-hex-string
