# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase (backend — set in Netlify dashboard, not here)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (backend — set in Netlify dashboard)
# ANTHROPIC_API_KEY=

# Admin panel passwords (frontend — bundled into JS, so use strong unique values)
# These are read by App.jsx via import.meta.env
VITE_ADMIN_PW_OWNER=change-me-owner
VITE_ADMIN_PW_CM=change-me-cm
VITE_ADMIN_PW_PUB=change-me-pub
